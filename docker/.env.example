# =============================================================================
# CodePop Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL password (required for production)
POSTGRES_PASSWORD=codepop123

# Full database connection URL (optional, can use individual params instead)
DATABASE_URL=postgresql://postgres:codepop123@localhost:5432/codepop

# -----------------------------------------------------------------------------
# Embedding Provider Configuration
# -----------------------------------------------------------------------------
# OpenAI API key for embeddings (required unless using alternative provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Embedding provider: openai, ollama, cohere
EMBEDDING_PROVIDER=openai

# Ollama configuration (if EMBEDDING_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Cohere configuration (if EMBEDDING_PROVIDER=cohere)
COHERE_API_KEY=your-cohere-api-key

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Main API server port
CODEPOP_PORT=3000

# MCP (Model Context Protocol) server port
CODEPOP_MCP_PORT=3001

# Node environment: development, production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# API key for authenticating requests (required for production)
API_KEY=your-secret-api-key-here

# Optional: JWT secret for token-based auth
# JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
# Docker Compose project name
COMPOSE_PROJECT_NAME=codepop

# Image tag for production deployments
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
# Directory for cloned repositories
REPOS_DIR=./repos

# Directory for application logs
LOGS_DIR=./logs

# -----------------------------------------------------------------------------
# Optional: External Services
# -----------------------------------------------------------------------------
# GitHub integration (optional)
# GITHUB_TOKEN=your-github-personal-access-token

# Redis configuration (optional, for caching)
# REDIS_URL=redis://localhost:6379
