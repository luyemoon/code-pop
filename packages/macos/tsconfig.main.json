{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@codepop/core": ["../core/src"]
    }
  },
  "include": ["src/main.ts", "src/preload.ts", "src/ipc/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/renderer", "src/components"]
}
