{
  "name": "@codepop/macos",
  "version": "0.1.0",
  "description": "CodePop macOS 原生应用 - Electron 构建",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "npm run build:main && electron .",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:mac": "npm run build && electron-builder --mac",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "jest"
  },
  "keywords": [
    "code-search",
    "electron",
    "macos"
  ],
  "author": "CodePop Team",
  "license": "MIT",
  "dependencies": {
    "@codepop/core": "workspace:*",
    "better-sqlite3": "^9.4.3",
    "electron-updater": "^6.1.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
